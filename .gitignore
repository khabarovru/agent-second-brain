# Vault personal data (never commit these)
# Структура: vault/ внутри репозитория (с новой нумерацией папок)

# Личные данные (00-95 папки — содержимое игнорируется, структура сохраняется)
vault/00 Входящие/*
!vault/00 Входящие/.gitkeep
!vault/00 Входящие/01 Web Clipper/
vault/00 Входящие/01 Web Clipper/*
!vault/00 Входящие/01 Web Clipper/.gitkeep

vault/10 Заметки/*
!vault/10 Заметки/.gitkeep

vault/20 Ежедневник/*
!vault/20 Ежедневник/.gitkeep

vault/30 Проекты/*
!vault/30 Проекты/.gitkeep

vault/40 Объекты/*
!vault/40 Объекты/.gitkeep

vault/50 Задачи/*
!vault/50 Задачи/.gitkeep

vault/60 Цели/*
!vault/60 Цели/.gitkeep

vault/70 Люди/*
!vault/70 Люди/.gitkeep

vault/80 Ежедневные/*
!vault/80 Ежедневные/.gitkeep

vault/85 Сводки/*
!vault/85 Сводки/.gitkeep

vault/90 Карты знаний/*
!vault/90 Карты знаний/.gitkeep

vault/95 Файлы/*
!vault/95 Файлы/.gitkeep

# Системные файлы с личной информацией
vault/MEMORY.md
vault/USER.md
vault/SOUL.md
vault/AGENTS.md
vault/IDENTITY.md
vault/HEARTBEAT.md
vault/TOOLS.md

# Obsidian workspace (содержит открытые заметки)
vault/.obsidian/workspace.json
vault/.obsidian/workspace-mobile.json
vault/.obsidian/workspace.json.bak*
vault/.obsidian/cache
vault/.obsidian/graph.json
vault/.obsidian/plugins/*/data.json

# Служебные папки
vault/.session/
vault/.sessions/
vault/.graph/
vault/.openclaw/
vault/attachments/
vault/thoughts/
vault/blog/
vault/MOC/

# Старая структура (если осталась)
vault/daily/
vault/contacts/
vault/finances/
vault/business/
vault/projects/
